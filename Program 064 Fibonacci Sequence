import java.util.*;

public class P064 {
    public static void main(String[] args) {

        Scanner input = new Scanner(System.in);

        System.out.print("How many Fibonacci numbers do you want? ");
        int n = input.nextInt();

        int first = 0;
        int second = 1;
        int next;

        for (int i = 1; i <= n; i++) {
            System.out.print(first + " ");

            next = first + second;
            first = second;
            second = next;
        }

        input.close();
    }
}
