import java.io.*;
import java.util.*;

public class P034 {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        System.out.print("Enter your age: ");
        int age = input.nextInt();

        if (age > 18) {
            System.out.println("You can vote");
        } else if (age < 18) {
            System.out.println("You're too young to vote");
        } else {
            System.out.println("You can vote");
        }

        input.close();
    }
}
